{
  "name": "hubris",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5317 --strictPort --host",
    "dev:preview": "vite --port \"${PORT:-5199}\" --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:ios": "npm run build && rm -rf apple/HUBRIS/web && cp -R dist apple/HUBRIS/web"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
